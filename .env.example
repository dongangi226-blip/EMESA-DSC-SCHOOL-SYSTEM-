# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/emesa_school
MONGODB_URI=mongodb://localhost:27017/emesa_school

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_password

# Frontend
REACT_APP_API_URL=http://localhost:5000/api

# AWS/Cloud Storage (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# Logging
LOG_LEVEL=debug
